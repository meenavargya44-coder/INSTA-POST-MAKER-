*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0f1e;--surface:#111827;--card:#1a2235;--border:#1e2d45;
  --text:#e8edf8;--text2:#8fa3c4;--text3:#4a5f7a;
  --accent:#3b82f6;--accent2:#2563eb;--green:#10b981;--green-bg:#052e16;
  --amber:#f59e0b;--purple:#8b5cf6;--radius:12px;--radius-sm:8px;
}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);min-height:100vh;padding:20px 16px}

/* Header */
.header{text-align:center;margin-bottom:28px;padding:24px 20px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius)}
.logo{font-size:13px;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px}
.header h1{font-size:24px;font-weight:700;color:var(--text);margin-bottom:6px}
.header p{font-size:13px;color:var(--text2)}
.badge-row{display:flex;justify-content:center;gap:8px;margin-top:12px;flex-wrap:wrap}
.badge{padding:4px 12px;border-radius:999px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.05em}
.badge.blue{background:rgba(59,130,246,.15);color:var(--accent);border:1px solid rgba(59,130,246,.3)}
.badge.green{background:rgba(16,185,129,.15);color:var(--green);border:1px solid rgba(16,185,129,.3)}

/* Search */
.search-card{max-width:600px;margin:0 auto 24px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px}
.search-label{font-size:12px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px}
.search-row{display:flex;gap:10px;flex-wrap:wrap}
.date-select{flex:1;min-width:180px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px 14px;color:var(--text);font-size:14px;font-family:inherit;outline:none;cursor:pointer;transition:border-color .2s}
.date-select:focus{border-color:var(--accent)}
.search-btn{padding:12px 24px;background:var(--accent);color:#fff;border:none;border-radius:var(--radius-sm);font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;white-space:nowrap}
.search-btn:hover{background:var(--accent2)}

/* Result */
.result{max-width:600px;margin:0 auto;display:none;flex-direction:column;gap:12px}
.result.visible{display:flex}

.result-header{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px 20px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
.result-date{font-size:18px;font-weight:700;color:var(--text)}
.result-service{padding:5px 14px;border-radius:999px;font-size:12px;font-weight:600;background:rgba(139,92,246,.15);color:var(--purple);border:1px solid rgba(139,92,246,.3)}

.content-block{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden}
.block-header{padding:10px 16px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border)}
.block-header.blue{background:rgba(59,130,246,.08);color:var(--accent)}
.block-header.green{background:rgba(16,185,129,.08);color:var(--green)}
.block-header.amber{background:rgba(245,158,11,.08);color:var(--amber)}
.block-header.purple{background:rgba(139,92,246,.08);color:var(--purple)}
.block-body{padding:16px;font-size:13.5px;color:var(--text);line-height:1.7;white-space:pre-wrap}

.copy-btn{background:rgba(255,255,255,.08);border:none;border-radius:6px;padding:4px 10px;font-size:11px;cursor:pointer;color:inherit;transition:all .15s;font-family:inherit}
.copy-btn:hover{background:rgba(255,255,255,.16)}
.copy-btn.copied{background:var(--green);color:#fff}

/* Image */
.img-grid{display:grid;grid-template-columns:1fr;gap:12px;padding:16px}
.scene-img{width:100%;border-radius:var(--radius-sm);object-fit:cover;min-height:200px;background:var(--card);display:block}

/* Download */
.download-bar{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;display:flex;gap:10px;flex-wrap:wrap}
.dl-btn{flex:1;padding:12px 16px;border-radius:var(--radius-sm);border:none;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;text-align:center;min-width:140px}
.dl-btn.primary{background:var(--accent);color:#fff}
.dl-btn.primary:hover{background:var(--accent2)}
.dl-btn.secondary{background:var(--card);color:var(--text2);border:1px solid var(--border)}
.dl-btn.secondary:hover{color:var(--text);border-color:var(--accent)}

/* Calendar mini grid */
.cal-section{max-width:600px;margin:0 auto 24px}
.cal-title{font-size:13px;font-weight:600;color:var(--text2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px;text-align:center}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px}
.cal-day-header{text-align:center;font-size:10px;font-weight:600;color:var(--text3);padding:4px;text-transform:uppercase}
.cal-day{text-align:center;padding:8px 4px;border-radius:var(--radius-sm);font-size:12px;cursor:pointer;border:1px solid var(--border);background:var(--card);color:var(--text2);transition:all .2s}
.cal-day:hover{border-color:var(--accent);color:var(--text)}
.cal-day.active{background:var(--accent);border-color:var(--accent);color:#fff;font-weight:700}
.cal-day.empty{background:transparent;border-color:transparent;cursor:default}

/* Footer */
.footer{text-align:center;margin-top:32px;font-size:12px;color:var(--text3)}
.footer a{color:var(--accent);text-decoration:none}

/* Mobile */
@media(max-width:640px){
  body{padding:14px 10px}
  .header h1{font-size:20px}
  .search-row{flex-direction:column}
  .search-btn{width:100%;padding:14px}
  .date-select{font-size:16px;padding:14px}
  .dl-btn{min-width:100px;font-size:12px}
  .cal-day{padding:6px 2px;font-size:11px}
}
</style>
