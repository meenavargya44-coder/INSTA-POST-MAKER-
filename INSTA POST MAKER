const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

function selectDay(day){
  // Update calendar highlight
  document.querySelectorAll('.cal-day').forEach(d => d.classList.remove('active'));
  event.target.classList.add('active');
  // Update dropdown
  document.getElementById('date-select').value = day;
  // Show content
  showContent();
}

function showContent(){
  const select = document.getElementById('date-select');
  const day = parseInt(select.value);
  if(!day){ alert('Pehle ek date select karo!'); return; }

  const data = content[day];
  if(!data){ alert('Is din ka content available nahi hai.'); return; }

  // Date string
  const date = new Date(2026, 6, day);
  const dayName = days[date.getDay()];
  document.getElementById('result-date').textContent = `${String(day).padStart(2,'0')} July 2026 — ${dayName}`;
  document.getElementById('result-service').textContent = data.service;

  // Fill content
  document.getElementById('caption-text').textContent = data.caption;
  document.getElementById('hashtag-text').textContent = data.hashtags;
  document.getElementById('script-text').textContent = data.script;

  // Image — Pollinations.ai free, no API key needed
  const seed = day * 137;
  const encoded = encodeURIComponent(data.imagePrompt + ', professional, high quality, business');
  const img = document.getElementById('post-image');
  img.onerror = function(){
    // Fallback: show placeholder with prompt text
    this.onerror = null;
    this.src = `https://picsum.photos/seed/${seed}/600/400`;
  };
  img.src = `https://image.pollinations.ai/prompt/${encoded}?width=600&height=400&seed=${seed}&nologo=true`;

  // Show result
  const result = document.getElementById('result');
  result.classList.add('visible');
  result.scrollIntoView({ behavior: 'smooth', block: 'start' });

  // Highlight calendar
  document.querySelectorAll('.cal-day').forEach(d => {
    d.classList.toggle('active', d.textContent.trim() === String(day));
  });
}

function copyText(id, btn){
  const el = document.getElementById(id);
  if(!el) return;
  navigator.clipboard.writeText(el.textContent).then(() => {
    btn.textContent = '✅ Copied!';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = '📋 Copy'; btn.classList.remove('copied'); }, 1500);
  });
}

function copyAll(){
  const day = parseInt(document.getElementById('date-select').value);
  if(!day) return;
  const caption = document.getElementById('caption-text').textContent;
  const hashtags = document.getElementById('hashtag-text').textContent;
  const script = document.getElementById('script-text').textContent;
  const text = `📅 ${String(day).padStart(2,'0')} July 2026 — GrowTogether Solutions\n\n📝 CAPTION:\n${caption}\n\n#️⃣ HASHTAGS:\n${hashtags}\n\n🎬 VIDEO SCRIPT:\n${script}`;
  navigator.clipboard.writeText(text).then(() => alert('Sab kuch copy ho gaya! ✅'));
}

function downloadContent(){
  const day = parseInt(document.getElementById('date-select').value);
  if(!day) return;
  const data = content[day];
  const caption = document.getElementById('caption-text').textContent;
  const hashtags = document.getElementById('hashtag-text').textContent;
  const script = document.getElementById('script-text').textContent;
  const text = `GROWTOGETHER SOLUTIONS — CONTENT CALENDAR\n${String(day).padStart(2,'0')} July 2026\n${'='.repeat(40)}\n\nSERVICE: ${data.service}\n\nCAPTION (Instagram / LinkedIn):\n${caption}\n\nHASHTAGS:\n${hashtags}\n\nVIDEO SCRIPT / REEL IDEA:\n${script}\n\nIMAGE PROMPT (for Kling AI / Pika):\n${data.imagePrompt}\n\n${'='.repeat(40)}\nGrowtogether Solutions · Rajkot, Gujarat\nPhone: +91 99797 01232\nWebsite: growtogethersolution.co.in`;
  const blob = new Blob([text], { type: 'text/plain' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `GrowTogether-July2026-Day${String(day).padStart(2,'0')}.txt`;
  a.click();
  URL.revokeObjectURL(url);
}

